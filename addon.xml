<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.reset_inprogress_episodes"
       name="Reset In-Progress Episodes"
       version="1.0.0"
       provider-name="ankurmittal"
       type="script">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary>Reset In-Progress Episodes</summary>
        <description>This add-on resets In-Progress Episodes.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>